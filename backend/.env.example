# Admin password for Expert Corner writes
ADMIN_PASSWORD=holygrail

# Optional AI providers (first available is used; otherwise local templates)
GEMINI_API_KEY=
OPENAI_API_KEY=
HF_TOKEN=

# Optional GitHub persistence for the watchlist (falls back to local file)
GITHUB_TOKEN=
GITHUB_REPO=ravichandran-urmila/holygrail-app
GITHUB_BRANCH=master
GITHUB_FILE_PATH=watchlist.json

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
